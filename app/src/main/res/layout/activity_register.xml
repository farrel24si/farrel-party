<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2FF"
    android:overScrollMode="never"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logos1"
            android:layout_marginTop="28dp"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Judul -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lengkapi Data Diri"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:textColor="#0D1B5E"
            android:textAlignment="center"
            android:layout_marginBottom="32dp" />

        <!-- Field: Nama Lengkap -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nama Lengkap"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#1565C0"
            app:boxStrokeWidthFocused="1.5dp"
            app:startIconDrawable="@android:drawable/ic_menu_edit"
            app:startIconTint="#1565C0"
            app:hintTextColor="#1565C0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:textColor="#0D1B5E"
                android:textSize="14sp"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Field: Email (disabled) -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email (Terisi Otomatis)"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="#E8EDF8"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#C5CEF0"
            app:startIconDrawable="@android:drawable/ic_dialog_email"
            app:startIconTint="#6B7CB8"
            app:hintTextColor="#6B7CB8">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:enabled="false"
                android:textColor="#6B7CB8"
                android:textSize="14sp"
                android:inputType="textEmailAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Field: Username -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username (Tanpa Spasi)"
            android:layout_marginBottom="16dp"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#1565C0"
            app:boxStrokeWidthFocused="1.5dp"
            app:startIconDrawable="@android:drawable/ic_menu_myplaces"
            app:startIconTint="#1565C0"
            app:hintTextColor="#1565C0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:textColor="#0D1B5E"
                android:textSize="14sp"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Field: Password -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password (Min. 6 Karakter)"
            android:layout_marginBottom="32dp"
            app:boxBackgroundColor="@android:color/white"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:boxStrokeColor="#1565C0"
            app:boxStrokeWidthFocused="1.5dp"
            app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
            app:startIconTint="#1565C0"
            app:hintTextColor="#1565C0"
            app:passwordToggleEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRegPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:textColor="#0D1B5E"
                android:textSize="14sp"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tombol Registrasi -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Registrasi"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="36dp"
            app:cornerRadius="14dp"
            app:backgroundTint="#1565C0"
            app:elevation="4dp" />

    </LinearLayout>
</ScrollView>