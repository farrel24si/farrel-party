<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F7">

    <View
        android:id="@+id/background_header"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_header_wave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:title="Pengajuan Peminjaman"
        app:titleTextColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Isi Detail Peminjaman"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Kegiatan"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:layout_marginBottom="8dp"/>

                    <EditText
                        android:id="@+id/etNamaKegiatan"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_rounded_container"
                        android:hint="Contoh: Rapat RT / Pernikahan"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="24dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih Fasilitas"
                        android:textColor="#424242"
                        android:textStyle="bold" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupFasilitas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="24dp"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipGedung"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gedung Serbaguna" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipLapangan"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lapangan Olahraga" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTenda"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tenda &amp; Kursi" />
                    </com.google.android.material.chip.ChipGroup>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tanggal Peminjaman"
                        android:textStyle="bold"
                        android:textColor="#424242" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTanggal"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:hint="DD/MM/YYYY"
                        app:startIconDrawable="@android:drawable/ic_menu_today"
                        app:boxStrokeColor="#0084FF"
                        app:hintTextColor="#0084FF">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTanggal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Layanan Tambahan (Grid)"
                        android:layout_marginTop="24dp"
                        android:textColor="#424242"
                        android:textStyle="bold" />

                    <androidx.gridlayout.widget.GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:columnCount="2"
                        app:useDefaultMargins="true"
                        android:layout_marginTop="8dp">

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:text="Sound System"
                            app:strokeColor="#0084FF"
                            android:textColor="#0084FF"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:text="Proyektor"
                            app:strokeColor="#0084FF"
                            android:textColor="#0084FF"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:text="Kebersihan"
                            app:strokeColor="#0084FF"
                            android:textColor="#0084FF"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal" />

                        <com.google.android.material.button.MaterialButton
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:text="Keamanan"
                            app:strokeColor="#0084FF"
                            android:textColor="#0084FF"
                            app:layout_columnWeight="1"
                            app:layout_gravity="fill_horizontal" />
                    </androidx.gridlayout.widget.GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitPeminjaman"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Ajukan Peminjaman"
                android:textColor="#FFFFFF"
                app:backgroundTint="#0084FF"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="#FFFFFF" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>